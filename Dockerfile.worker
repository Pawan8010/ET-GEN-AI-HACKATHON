FROM python:3.12-slim AS runtime
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1 PYTHONPATH=/opt/opsbrain/backend
WORKDIR /opt/opsbrain
RUN groupadd --system opsbrain && useradd --system --gid opsbrain --home /opt/opsbrain opsbrain
COPY backend/pyproject.toml ./backend/pyproject.toml
COPY backend/opsbrain_backend ./backend/opsbrain_backend
RUN python -m pip install --upgrade pip && python -m pip install ./backend
USER opsbrain
CMD ["python", "-m", "opsbrain_backend.worker"]
