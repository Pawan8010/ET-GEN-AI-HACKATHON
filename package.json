{
  "name": "opsbrain-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python -m uvicorn opsbrain_backend.main:app --app-dir backend --reload --port 8000",
    "dev:client": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "start": "python -m uvicorn opsbrain_backend.main:app --app-dir backend --host 0.0.0.0 --port 8000",
    "backend:dev": "python -m uvicorn opsbrain_backend.main:app --app-dir backend --reload --port 8000",
    "test:backend": "python -m pytest backend/tests -q",
    "verify": "npm run test:backend && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "d3": "^7.9.0",
    "firebase": "^12.16.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
